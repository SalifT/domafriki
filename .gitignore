/bin
/html/core
/html/modules/contrib
/html/profiles/contrib
/html/themes/contrib
/html/sites/default/files
/html/libraries
vendor/
.idea

# Ignore the local settings files.
html/sites/*/settings.local.php
html/sites/*/settings.php.original

# Ignore specifics environment ($env) settings files.
html/sites/*/settings.*.php

# Ignore specifics environment ($env) services files.
html/sites/*/services.*.yml

#Ignore Drupal file directory
/html/sites/*/files/

# Ignore .env files as they are specific to user environment.
/.env

# Ignore Virtual Studio code editor files.
.vscode/

# Ignore private files.
/private/*
# But don't Ignore private/.htaccess file on <production> environment.
# # Note: .htaccess files are ignored in development <dev> environment.
!/private/.htaccess

# Don't Ignore config/sync/.htaccess file on <production> environment.
# # Note: .htaccess files are ignored in development <dev> environment.
!/config/sync/.htaccess

# Ignore Drupal scaffold files generated by Composer.
/html/sites/default/default.services.yml
/html/sites/default/default.settings.php
/html/sites/development.services.yml
/html/sites/example.settings.local.php
/html/sites/example.sites.php
/html/.csslintrc
/html/.editorconfig
/html/.eslintignore
/html/.eslintrc.json
/html/.gitattributes
/html/.ht.router.php
/html/.htaccess
/html/autoload.php
/html/index.php
/html/robots.txt
/html/update.php
/html/web.config
